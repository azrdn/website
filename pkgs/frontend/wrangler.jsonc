{
  "$schema": "../../node_modules/wrangler/config-schema.json",
  "name": "web",
  "compatibility_date": "2026-06-30",
  "compatibility_flags": ["nodejs_compat"],
  "assets": {
    "directory": "./dist",
    "not_found_handling": "404-page",
    "run_worker_first": ["/guestbook/", "/_server-islands/*"]
  },
  "dev": {
    "port": 4321
  }
}
