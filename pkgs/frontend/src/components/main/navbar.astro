---
import MenuIcon from "../icons/menu.svg";

interface Props {
  /** custom text for last breadcrumb segment */
  label?: string;
}

const links: { text: string; href: string; desc: string }[] = [
  { text: "/about", href: "/about/", desc: "who am i?" },
  { text: "/blog", href: "/blog/", desc: "i write too" },
  { text: "/projects", href: "/projects/", desc: "things i made" },
];

const { label } = Astro.props;
const path_segments = Astro.url.pathname.split("/").filter(Boolean);
const breadcrumb_segments = path_segments.map((segment, index, orig) => {
  return {
    text: decodeURIComponent(segment),
    href: `/${orig.slice(0, index + 1).join("/")}`,
    index,
  };
});
---

<header class="topheader">
  <nav id="label" aria-label="Breadcrumb">
    <a class="navlink" href="/" aria-label="Home">~</a><span class="separator">/</span>
    <slot name="breadcrumb">
      {breadcrumb_segments.map((segment, index, orig) => (
        <Fragment>
          {segment.index !== 0 && <span class="separator">/</span>}
          <span class="crumb">
            <a class="navlink" href={segment.href}>
              {index === orig.length - 1 && label ? label : segment.text}
            </a>
          </span>
        </Fragment>
      ))}
    </slot>
  </nav>
  <button id="burger" popovertarget="navbar-s" title="Menu" aria-label="Toggle navigation">
    <MenuIcon />
  </button>

  <nav popover id="navbar-s">
    <div class="desc">
      {links.map((link) => <span>{link.desc}</span>)}
    </div>
    <div class="links">
      {
        links.map((link) => (
          <a class="navlink" href={link.href}>
            {link.text}
          </a>
        ))
      }
    </div>
  </nav>
  <nav id="navbar-l">
    {
      links.map((link) => (
        <a class="navlink" href={link.href}>
          {link.text}
        </a>
      ))
    }
  </nav>
</header>

<script>
  const header = document.querySelector<HTMLElement>(".topheader")!;
  const mobile_menu = document.querySelector<HTMLElement>("#navbar-s")!;
  let last_scroll_top = 0;

  document.addEventListener(
    "scroll",
    () => {
      const scroll_top = window.scrollY || document.documentElement.scrollTop;
      const dir = scroll_top > last_scroll_top ? "down" : "up";
      if (Math.abs(scroll_top - last_scroll_top) > 5) {
        header.setAttribute("scroll-direction", dir);
      }
      last_scroll_top = scroll_top <= 0 ? 0 : scroll_top;
      mobile_menu.hidePopover();
    },
    { passive: true },
  );

  const mobile_links = mobile_menu.querySelectorAll("a")!;
  mobile_links.forEach((a) => {
    a.addEventListener("click", () => mobile_menu.hidePopover());
  });
</script>

<style>
  header {
    display: flex;
    gap: 3ch;
    justify-content: space-between;
    border-bottom: 1px solid var(--bg-secondary);
    padding: 1rlh 2.5ch;
    background-color: var(--bg);
    position: fixed;
    width: 100%;
    max-width: var(--max-width);
    z-index: 2;
    top: 0;
    transition: transform 0.2s ease;

    #label {
      display: flex;
      column-gap: 0.5ch;
      white-space: nowrap;
      overflow: hidden;
      flex: 1;
      color: var(--fg);

      .crumb {
        display: inline-flex;
      }

      .separator {
        color: var(--fg-secondary);
      }
    }

    &[scroll-direction="down"] {
      transform: translateY(-100%);
      pointer-events: none;
    }
  }

  #burger {
    all: unset;
    -webkit-tap-highlight-color: transparent;

    &:focus {
      color: var(--fg);
      background-color: unset;
    }
  }

  .navlink {
    text-decoration: none;
  }

  .links,
  .desc {
    display: flex;
    flex-direction: column;
    gap: 1rlh;
  }

  .links {
    text-align: right;
  }

  #navbar-s[popover] {
    opacity: 0;
    transform: translateY(-1rlh);

    top: calc(2rlh + 1lh);
    color: var(--fg-secondary);
    background-color: var(--bg);
    justify-content: space-between;
    border: none;
    width: 100%;
    max-width: 80ch;
    margin: 0 auto;
    padding: 0 2.5ch 1lh;

    @media (prefers-reduced-motion: no-preference) {
      transition:
        opacity 0.2s,
        transform 0.2s,
        display 0.2s allow-discrete;
    }
  }

  #navbar-s:popover-open {
    opacity: 1;
    transform: none;

    @starting-style {
      & {
        opacity: 0;
        transform: translateY(-1rlh);
      }
    }

    display: flex;
    border-bottom: 1px solid var(--bg-secondary);
  }

  #navbar-l {
    display: none;
  }

  @media (width >= 768px) {
    #burger,
    #navbar-s[popover] {
      display: none;
    }

    #navbar-l {
      display: flex;
      gap: 3ch;
    }
  }
</style>
