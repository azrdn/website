---
import MenuIcon from "../icons/menu.svg";

interface Props {
  /** custom text for last breadcrumb segment */
  label?: string;
}

const links: { text: string; href: string; desc: string }[] = [
  { text: "/about", href: "/about/", desc: "who am i?" },
  { text: "/blog", href: "/blog/", desc: "i write too" },
  { text: "/projects", href: "/projects/", desc: "things i made" },
];

const { label } = Astro.props;
const path_segments = Astro.url.pathname.split("/").filter(Boolean);
const breadcrumbs = path_segments.map((segment, index, orig) => {
  return {
    text: decodeURIComponent(segment),
    href: `/${orig.slice(0, index + 1).join("/")}`,
    index,
  };
});

if (!breadcrumbs.length && label)
  breadcrumbs.push({
    text: label,
    href: "/",
    index: 0,
  });
---

<div class="spacer"></div>
<header class="topheader">
  <nav id="label" aria-label="Breadcrumb">
    <a class="navlink" href="/" aria-label="Home">~</a>
    <span class="separator">/</span>
    <slot name="breadcrumb">
      {
        breadcrumbs.map((crumb, index, orig) => (
          <Fragment>
            {crumb.index !== 0 && <span class="separator">/</span>}
            <span class="crumb">
              <a class="navlink" href={crumb.href}>
                {index === orig.length - 1 && label ? label : crumb.text}
              </a>
            </span>
          </Fragment>
        ))
      }
    </slot>
  </nav>
  <button
    id="burger"
    popovertarget="navbar-s"
    title="Menu"
    aria-label="Toggle navigation"
  >
    <MenuIcon />
  </button>

  <nav popover id="navbar-s">
    <div class="desc">
      {links.map((link) => <span>{link.desc}</span>)}
    </div>
    <div class="links">
      {
        links.map((link) => (
          <a class="navlink" href={link.href}>
            {link.text}
          </a>
        ))
      }
    </div>
  </nav>
  <nav id="navbar-l">
    {
      links.map((link) => (
        <a class="navlink" href={link.href}>
          {link.text}
        </a>
      ))
    }
  </nav>
</header>

<script>
  const header = document.querySelector<HTMLElement>(".topheader")!;
  const mobileMenu = document.querySelector<HTMLElement>("#navbar-s")!;
  const mq = window.matchMedia("(prefers-reduced-motion: no-preference)");
  let lastScrollTop = 0;

  if (mq.matches)
    document.addEventListener(
      "scroll",
      () => {
        const scroll_top = window.scrollY || document.documentElement.scrollTop;
        const dir = scroll_top > lastScrollTop ? "down" : "up";
        if (Math.abs(scroll_top - lastScrollTop) > 1) {
          header.setAttribute("scroll-direction", dir);
        }
        lastScrollTop = scroll_top <= 0 ? 0 : scroll_top;
        mobileMenu.hidePopover();
      },
      { passive: true },
    );

  const mobileLinks = mobileMenu.querySelectorAll("a")!;
  mobileLinks.forEach((a) => {
    a.addEventListener("click", () => mobileMenu.hidePopover());
  });
</script>

<style>
  .spacer {
    position: absolute;
    top: 0;
    height: calc(2rlh + 1lh);
    width: 100%;
    max-width: var(--max-width);
    background-color: var(--bg);
  }

  header {
    display: flex;
    justify-content: space-between;
    width: 100%;
    max-width: var(--max-width);
    position: sticky;
    top: 0;
    gap: 3ch;
    z-index: 2;
    padding: 1rlh var(--side-padding);
    border-bottom: 1px solid var(--bg-secondary);
    background-color: var(--bg);
    transition: transform 0.2s;

    #label {
      display: flex;
      column-gap: 0.5ch;
      white-space: nowrap;
      overflow: hidden;
      flex: 1;
      color: var(--fg);

      .crumb {
        display: inline-flex;
      }

      .separator {
        color: var(--fg-secondary);
      }
    }

    &[scroll-direction="down"] {
      transform: translateY(-100%);
      pointer-events: none;
    }
  }

  #burger {
    all: unset;
    -webkit-tap-highlight-color: transparent;

    &:focus {
      color: var(--accent);
      background-color: unset;
    }
  }

  .navlink {
    text-decoration: none;
  }

  .links,
  .desc {
    display: flex;
    flex-direction: column;
    gap: 1rlh;
  }

  .links {
    text-align: right;
  }

  #navbar-s[popover] {
    opacity: 0;
    transform: translateY(-1rlh);

    top: calc(2rlh + 1lh);
    color: var(--fg-secondary);
    background-color: var(--bg);
    justify-content: space-between;
    border: none;
    width: 100%;
    max-width: 80ch;
    margin: 0 auto;
    padding: 0 var(--side-padding) 1lh;

    @media (prefers-reduced-motion: no-preference) {
      transition:
        opacity 0.2s,
        transform 0.2s,
        display 0.2s allow-discrete;
    }
  }

  #navbar-s:popover-open {
    opacity: 1;
    transform: none;

    @starting-style {
      & {
        opacity: 0;
        transform: translateY(-1rlh);
      }
    }

    display: flex;
    border-bottom: 1px solid var(--bg-secondary);
  }

  #navbar-l {
    display: none;
  }

  @media (width >= 768px) {
    #burger,
    #navbar-s[popover] {
      display: none;
    }

    #navbar-l {
      display: flex;
      gap: 3ch;
    }
  }
</style>
