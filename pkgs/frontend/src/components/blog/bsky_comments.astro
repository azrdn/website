---
import likeIcon from "../icons/heart-fill.svg?raw";
import replyIcon from "../icons/message-fill.svg?raw";

interface Props {
  uri: string;
}

const { uri } = Astro.props;
const isAT = uri.startsWith("at:");
---

<script>
  import "bsky-comments";
</script>
<bsky-comments
  post={isAT ? undefined : uri}
  uri={isAT ? uri : undefined}
  icon-like={likeIcon}
  icon-reply={replyIcon}
>
</bsky-comments>

<style is:global>
  .bsky-header,
  .bsky-meta,
  .bsky-comment-header,
  .bsky-icon,
  .bsky-actions,
  .bsky-like,
  .bsky-reply {
    display: flex;
  }

  .bsky-header {
    justify-content: space-between;
    column-gap: 5ch;
    margin: 1lh 0;
  }

  .bsky-reply-btn {
    text-align: right;
  }

  .bsky-meta {
    flex-direction: column;
    column-gap: 1ch;

    @media (min-width: 600px) {
      flex-direction: row;
    }
  }

  .bsky-date {
    text-decoration: none;
    color: var(--fg-secondary);
  }

  .bsky-comment {
    border: 1px solid var(--bg-secondary);
    padding: 1em calc(2ch - 2px);
    background-color: color-mix(in srgb, var(--bg-secondary), transparent 75%);
    margin-top: 1em;
  }

  .bsky-comment-header {
    column-gap: 1ch;
  }

  .bsky-avatar {
    width: 5ch;
    height: 5ch;
  }

  .bsky-icon {
    height: 1em;
    width: 2ch;
    align-self: center;
  }

  .bsky-actions {
    column-gap: 2ch;
  }
</style>
