---
import { ISO } from "@utils/date";

interface Props {
  title: string;
  href: string;
  date: Date;
}

const { title, href, date } = Astro.props;
---

<a class="post box" {href}>
  <article>{title}</article>
  <time datetime={ISO(date)} title={ISO(date)}>{ISO(date, true)}</time>
</a>

<style>
  a {
    text-decoration: none;
  }

  .post {
    display: flex;
    flex-direction: column;
    row-gap: 1em;
    margin: 1em 0;
  }

  time {
    color: var(--fg-secondary);
  }

  @media (width >= 768px) {
    .post {
      flex-direction: row;
      justify-content: space-between;
    }

    article {
      max-width: 70%;
    }
  }
</style>
