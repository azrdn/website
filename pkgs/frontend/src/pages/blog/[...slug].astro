---
import { getCollection, render } from "astro:content"
import type { GetStaticPaths } from "astro"
import CodeBtns from "@components/blog/codeblock_btns.astro"
import Footer from "@components/main/footer.astro"
import Navbar from "@components/main/navbar.astro"
import Toc from "@components/blog/toc.astro"
import Layout from "@components/layout.astro"

import "../../styles/blog.css"

const iso_date = (date: Date) => date.toISOString().slice(0, 10)

export const getStaticPaths = (async () => {
	const collection = await getCollection("blog")
	return collection.map(post => ({
		params: { slug: post.id },
		props: { post },
	}))
}) satisfies GetStaticPaths

const { post } = Astro.props
const { Content, headings } = await render(post)
---

<Layout title={post.data.title}>
	<Navbar slot="header" />
	<article>
		<header>
			<h1>{post.data.title}</h1>
			<p id="info">
				<span>Publ: <time>{iso_date(post.data.createdAt)}</time></span>
				{post.data.updatedAt &&
					<span>Upd: <time>{iso_date(post.data.updatedAt)}</time></span>
				}
			</p>
			{
				headings.length > 0 && (
					<details id="toc">
						<summary>Table of Contents</summary>
						<Toc {headings} />
					</details>
				)
			}
		<hr />
		</header>
		<Content />
	</article>
	<CodeBtns />
	<Footer slot="footer" />
</Layout>

<style>
	#info {
		display: flex;
		flex-wrap: wrap;
		gap: 0.5em 2ch;

		> * {
			border: 1px solid var(--bg-secondary);
			padding: 0.1em calc(1ch - 1px);
		}

		#pageviews {
			display: inline-block;
			width: 3ch;
			text-align: right;
		}
	}

	@media (width >= 1600px) {
		#toc {
			position: fixed;
			padding: 1rlh 2ch;
			background-color: var(--bg);
			top: 0;
			margin: 0;
			right: 3ch;
			max-height: 90svh;
			width: 35ch;

			&[open] {
				overflow-y: scroll;
			}
		}
	}

	:global(body:has(#toc:hover) .topheader) {
		transform: none;
	}
</style>
