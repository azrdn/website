---
interface Props {
	tag?: string;
	[key: string]: any;
}

const { tag, ...restProps } = Astro.props;
const Element = tag || "div";
---

<Element {...restProps} data-box>
	<slot />
</Element>

<style>
	[data-box] {
		border: 1px solid var(--bg-secondary);
		padding: 1em calc(2ch - 2px);
		background-color: color-mix(in srgb, var(--bg-secondary), transparent 75%);
	}
</style>
